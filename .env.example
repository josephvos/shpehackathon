# ===========================================
# YouTube Video Translator - Environment Template
# ===========================================
# Copy this file to .env and fill in your actual values
# The .env file will be ignored by git for security

# ===========================================
# LibreTranslate Configuration
# ===========================================
LIBRETRANSLATE_HOST=127.0.0.1
LIBRETRANSLATE_PORT=5000
LIBRETRANSLATE_API_KEY=your-api-key-here-if-using-hosted-version

# ===========================================
# Application Settings
# ===========================================
# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Backend API URL 
BACKEND_URL=http://localhost:8080

# ===========================================
# Optional External Services (if added later)
# ===========================================
# YouTube Data API (if you want video metadata)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Google Cloud Translation (alternative to LibreTranslate)
GOOGLE_CLOUD_API_KEY=your-google-cloud-key-here

# Azure Translator (alternative to LibreTranslate)
AZURE_TRANSLATOR_KEY=your-azure-key-here
AZURE_TRANSLATOR_REGION=your-azure-region-here

# OpenAI API (if adding ChatGPT integration)
OPENAI_API_KEY=your-openai-api-key-here

# ===========================================
# Database Settings (if using database later)
# ===========================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=subtitle_translator
DB_USER=your-db-username
DB_PASSWORD=your-db-password

# ===========================================
# Security Settings
# ===========================================
# JWT secret for authentication (if adding user accounts)
JWT_SECRET=your-very-long-random-secret-key-here

# Session secret
SESSION_SECRET=your-session-secret-here

# ===========================================
# Development vs Production
# ===========================================
NODE_ENV=development
SPRING_PROFILES_ACTIVE=development

# ===========================================
# INSTRUCTIONS
# ===========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in the .env file
# 3. Never commit the .env file to git
# 4. The .env file is already in .gitignore for protection
